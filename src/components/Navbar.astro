---
const links = [
  { label: "Menú", href: "#menu" },
  { label: "Nosotros", href: "#nosotros" },
  { label: "Reservaciones", href: "#reservaciones" },
  { label: "Ubicación", href: "#ubicacion" },
];
---

<header id="navbar" style="
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  padding: 0 40px;
">
  <nav style="
    max-width: 1100px;
    margin: 0 auto;
    padding: 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  " id="nav-inner">

    <!-- Logo -->
    <a href="/" style="text-decoration: none; display: flex; flex-direction: column; line-height: 1;">
      <span style="
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        font-weight: 700;
        color: #f5efe6;
        letter-spacing: -0.3px;
      " id="logo-name">Origen</span>
      <span style="
        font-family: 'DM Sans', sans-serif;
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #c8956c;
      ">Café & Brunch</span>
    </a>

    <!-- Links desktop -->
    <ul id="nav-links" style="
      display: flex;
      align-items: center;
      gap: 40px;
      list-style: none;
      margin: 0;
      padding: 0;
    ">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link"
            style="
              font-size: 13px;
              font-weight: 500;
              letter-spacing: 0.05em;
              text-transform: uppercase;
              color: rgba(245,239,230,0.8);
              text-decoration: none;
              transition: color 0.2s ease;
              position: relative;
            "
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div id="nav-cta">
      <a
        href="#reservaciones"
        style="
          font-size: 13px;
          font-weight: 600;
          letter-spacing: 0.08em;
          text-transform: uppercase;
          color: #1a0f0a;
          background: #c8956c;
          padding: 11px 24px;
          border-radius: 4px;
          text-decoration: none;
          transition: background 0.2s ease;
        "
        onmouseover="this.style.background='#8b5e3c'; this.style.color='#f5efe6'"
        onmouseout="this.style.background='#c8956c'; this.style.color='#1a0f0a'"
      >
        Reservar mesa
      </a>
    </div>

    <!-- Hamburger -->
    <button id="menu-btn" style="
      display: none;
      flex-direction: column;
      gap: 5px;
      padding: 6px;
      background: none;
      border: none;
      cursor: pointer;
    " aria-label="Menu">
      <span id="bar1" style="display: block; width: 24px; height: 1.5px; background: #f5efe6; border-radius: 2px;"></span>
      <span id="bar2" style="display: block; width: 24px; height: 1.5px; background: #f5efe6; border-radius: 2px;"></span>
      <span id="bar3" style="display: block; width: 24px; height: 1.5px; background: #f5efe6; border-radius: 2px;"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="
    display: none;
    background: #f5efe6;
    border-top: 1px solid rgba(200,149,108,0.2);
  ">
    <div style="
      max-width: 1100px;
      margin: 0 auto;
      padding: 16px 0 24px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    ">
      {links.map((link) => (
        <a
          href={link.href}
          style="
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #1a0f0a;
            text-decoration: none;
            padding: 12px 0;
            border-bottom: 1px solid rgba(26,15,10,0.06);
            transition: color 0.2s;
          "
          onmouseover="this.style.color='#c8956c'"
          onmouseout="this.style.color='#1a0f0a'"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#reservaciones"
        style="
          font-size: 13px;
          font-weight: 600;
          letter-spacing: 0.08em;
          text-transform: uppercase;
          color: #1a0f0a;
          background: #c8956c;
          padding: 14px 0;
          border-radius: 4px;
          text-align: center;
          text-decoration: none;
          margin-top: 12px;
        "
      >
        Reservar mesa
      </a>
    </div>
  </div>
</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: #c8956c;
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  @media (max-width: 768px) {
    #navbar {
      padding: 0 24px !important;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const navbar = document.getElementById("navbar") as HTMLElement;
  const navInner = document.getElementById("nav-inner") as HTMLElement;
  const logoName = document.getElementById("logo-name") as HTMLElement;
  const navLinks = document.querySelectorAll<HTMLElement>(".nav-link");
  const menuBtn = document.getElementById("menu-btn") as HTMLElement;
  const navCta = document.getElementById("nav-cta") as HTMLElement;
  const navLinksList = document.getElementById("nav-links") as HTMLElement;
  const mobileMenu = document.getElementById("mobile-menu") as HTMLElement;
  const bars = [
    document.getElementById("bar1"),
    document.getElementById("bar2"),
    document.getElementById("bar3"),
  ];

  // Entrada inicial
  gsap.set(navbar, { opacity: 0, y: -20 });
  gsap.to(navbar, { opacity: 1, y: 0, duration: 1, ease: "power3.out", delay: 0.5 });

  // Scroll: transparente sobre hero → crema al salir
  let scrolled = false;

  function updateNavbar() {
    const heroHeight = window.innerHeight;
    const current = window.scrollY;
    const isScrolled = current > heroHeight * 0.85;

    if (isScrolled && !scrolled) {
      scrolled = true;
      navbar.style.background = "#f5efe6";
      navbar.style.boxShadow = "0 1px 0 rgba(26,15,10,0.08)";
      navInner.style.padding = "16px 0";
      logoName.style.color = "#1a0f0a";
      navLinks.forEach(l => l.style.color = "rgba(26,15,10,0.6)");
      bars.forEach(b => { if (b) b.style.background = "#1a0f0a"; });
    } else if (!isScrolled && scrolled) {
      scrolled = false;
      navbar.style.background = "transparent";
      navbar.style.boxShadow = "none";
      navInner.style.padding = "22px 0";
      logoName.style.color = "#f5efe6";
      navLinks.forEach(l => l.style.color = "rgba(245,239,230,0.8)");
      bars.forEach(b => { if (b) b.style.background = "#f5efe6"; });
    }
  }

  // Hide/show on scroll
  let lastScroll = 0;
  let hidden = false;

  window.addEventListener("scroll", () => {
    const current = window.scrollY;
    const delta = current - lastScroll;
    const heroHeight = window.innerHeight;

    updateNavbar();

    if (current < heroHeight) {
      if (hidden) {
        gsap.to(navbar, { y: 0, opacity: 1, duration: 0.45, ease: "power3.out" });
        hidden = false;
      }
    } else if (delta > 6 && !hidden) {
      gsap.to(navbar, { y: -100, opacity: 0, duration: 0.35, ease: "power2.in" });
      hidden = true;
    } else if (delta < -6 && hidden) {
      gsap.to(navbar, { y: 0, opacity: 1, duration: 0.45, ease: "power3.out" });
      hidden = false;
    }

    lastScroll = current;
  }, { passive: true });

  // Responsive
  function handleResize() {
    if (window.innerWidth < 768) {
      navLinksList.style.display = "none";
      navCta.style.display = "none";
      menuBtn.style.display = "flex";
    } else {
      navLinksList.style.display = "flex";
      navCta.style.display = "block";
      menuBtn.style.display = "none";
      mobileMenu.style.display = "none";
    }
  }

  handleResize();
  window.addEventListener("resize", handleResize);

  // Hamburger
  let open = false;

  menuBtn.addEventListener("click", () => {
    open = !open;

    if (open) {
      navbar.style.background = "#f5efe6";
      logoName.style.color = "#1a0f0a";
      bars.forEach(b => { if (b) b.style.background = "#1a0f0a"; });
      mobileMenu.style.display = "block";
      gsap.from(mobileMenu, { opacity: 0, y: -10, duration: 0.25, ease: "power2.out" });
    } else {
      gsap.to(mobileMenu, {
        opacity: 0, y: -10, duration: 0.2, ease: "power2.in",
        onComplete: () => {
          mobileMenu.style.display = "none";
          gsap.set(mobileMenu, { opacity: 1, y: 0 });
          if (!scrolled) {
            navbar.style.background = "transparent";
            logoName.style.color = "#f5efe6";
            bars.forEach(b => { if (b) b.style.background = "#f5efe6"; });
          }
        }
      });
    }

    if (open) {
      gsap.to(bars[0], { rotate: 45, y: 6.5, duration: 0.3 });
      gsap.to(bars[1], { opacity: 0, duration: 0.2 });
      gsap.to(bars[2], { rotate: -45, y: -6.5, duration: 0.3 });
    } else {
      gsap.to(bars[0], { rotate: 0, y: 0, duration: 0.3 });
      gsap.to(bars[1], { opacity: 1, duration: 0.2 });
      gsap.to(bars[2], { rotate: 0, y: 0, duration: 0.3 });
    }
  });

  mobileMenu.querySelectorAll("a").forEach(link => {
    link.addEventListener("click", () => {
      open = false;
      mobileMenu.style.display = "none";
      gsap.to(bars[0], { rotate: 0, y: 0, duration: 0.3 });
      gsap.to(bars[1], { opacity: 1, duration: 0.2 });
      gsap.to(bars[2], { rotate: 0, y: 0, duration: 0.3 });
    });
  });
</script>