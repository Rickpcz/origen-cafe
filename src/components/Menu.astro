---
const destacados = [
  {
    nombre: "Avocado Toast",
    descripcion: "Pan artesanal tostado, aguacate machacado, huevo poché, microgreens y aceite de oliva extra virgen.",
    precio: "$145",
    imagen: "https://images.unsplash.com/photo-1623691752472-a6d33855e5de?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
    badge: "Chef's pick",
    categoria: "Brunch",
  },
  {
    nombre: "Huevos Benedictinos",
    descripcion: "Muffin inglés, jamón serrano, huevo pochado y salsa holandesa al estragón.",
    precio: "$155",
    imagen: "https://images.unsplash.com/photo-1608039829572-78524f79c4c7?w=800&q=80",
    badge: "Favorito",
    categoria: "Brunch",
  },
  {
    nombre: "Pancakes de Ricotta",
    descripcion: "Pancakes esponjosos con ricotta fresca, miel de abeja, frutos rojos y mantequilla de avellana.",
    precio: "$135",
    imagen: "https://images.unsplash.com/photo-1567620905732-2d1ec7ab7445?w=800&q=80",
    badge: null,
    categoria: "Brunch",
  },
  {
    nombre: "Latte de Especialidad",
    descripcion: "Espresso doble con leche texturizada al vapor. Origen único: Chiapas, tostión media.",
    precio: "$75",
    imagen: "https://images.unsplash.com/photo-1461023058943-07fcbe16d735?w=800&q=80",
    badge: "Origen único",
    categoria: "Bebidas",
  },
  {
    nombre: "Tarta de Limón",
    descripcion: "Base de galleta, crema de limón amarillo, merengue italiano tostado al momento.",
    precio: "$95",
    imagen: "https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=800&q=80",
    badge: "Temporada",
    categoria: "Postres",
  },
  {
    nombre: "Cold Brew",
    descripcion: "Infusión en frío por 18 horas. Notas de chocolate oscuro y caramelo. Servido con hielo.",
    precio: "$85",
    imagen: "https://images.unsplash.com/photo-1517701604599-bb29b565090c?w=800&q=80",
    badge: null,
    categoria: "Bebidas",
  },
];
---

<section id="menu" style="
  background: #f5efe6;
  padding: 120px 24px;
  position: relative;
  overflow: hidden;
">

  <!-- Decoración fondo -->
  <div style="
    position: absolute;
    top: 0; right: -200px;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,149,108,0.08) 0%, transparent 70%);
    pointer-events: none;
  "></div>

  <div style="max-width: 1100px; margin: 0 auto;">

    <!-- Header -->
    <div class="menu-header" style="
      text-align: center;
      margin-bottom: 72px;
    ">
      <div style="
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
      ">
        <div style="height: 1px; width: 32px; background: #c8956c;"></div>
        <span style="
          font-family: 'DM Sans', sans-serif;
          font-size: 12px;
          font-weight: 500;
          letter-spacing: 0.2em;
          text-transform: uppercase;
          color: #c8956c;
        ">Destacados de la carta</span>
        <div style="height: 1px; width: 32px; background: #c8956c;"></div>
      </div>

      <h2 style="
        font-family: 'Playfair Display', serif;
        font-size: clamp(36px, 5vw, 56px);
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -1.5px;
        color: #1a0f0a;
        margin-bottom: 16px;
      ">
        Hecho con<br/>
        <em style="font-style: italic; color: #c8956c;">intención</em>
      </h2>

      <p style="
        font-family: 'DM Sans', sans-serif;
        font-size: 15px;
        font-weight: 300;
        color: rgba(26,15,10,0.5);
        line-height: 1.7;
        max-width: 400px;
        margin: 0 auto;
      ">
        Una selección de nuestros platos más queridos. Ingredientes de temporada, productores locales.
      </p>
    </div>

    <!-- Grid destacados -->
    <div id="menu-grid" style="
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-bottom: 2px;
    ">
      {destacados.map((plato) => (
        <div
          class="menu-card"
          style="
            position: relative;
            overflow: hidden;
            aspect-ratio: 3/4;
            cursor: default;
            background: #1a0f0a;
          "
        >
          <!-- Imagen -->
          <img
            src={plato.imagen}
            alt={plato.nombre}
            class="card-img"
            style="
              width: 100%;
              height: 100%;
              object-fit: cover;
              transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.7s ease;
              opacity: 0.88;
            "
          />

          <!-- Overlay -->
          <div style="
            position: absolute;
            inset: 0;
            background: linear-gradient(
              to top,
              rgba(26,15,10,0.92) 0%,
              rgba(26,15,10,0.3) 50%,
              transparent 100%
            );
          "></div>

          <!-- Badge -->
          {plato.badge && (
            <div style="
              position: absolute;
              top: 20px;
              left: 20px;
              font-family: 'DM Sans', sans-serif;
              font-size: 10px;
              font-weight: 600;
              letter-spacing: 0.12em;
              text-transform: uppercase;
              color: #1a0f0a;
              background: #c8956c;
              padding: 4px 10px;
              border-radius: 2px;
            ">
              {plato.badge}
            </div>
          )}

          <!-- Info -->
          <div style="
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 28px 24px;
          ">
            <div style="
              font-family: 'DM Sans', sans-serif;
              font-size: 11px;
              font-weight: 500;
              letter-spacing: 0.15em;
              text-transform: uppercase;
              color: #c8956c;
              margin-bottom: 6px;
            ">
              {plato.categoria}
            </div>
            <div style="
              display: flex;
              align-items: flex-end;
              justify-content: space-between;
              gap: 12px;
            ">
              <h3 style="
                font-family: 'Playfair Display', serif;
                font-size: clamp(18px, 2vw, 22px);
                font-weight: 700;
                color: #f5efe6;
                line-height: 1.2;
              ">
                {plato.nombre}
              </h3>
              <span style="
                font-family: 'Playfair Display', serif;
                font-size: 20px;
                font-weight: 600;
                color: #c8956c;
                white-space: nowrap;
              ">
                {plato.precio}
              </span>
            </div>
            <p class="card-desc" style="
              font-family: 'DM Sans', sans-serif;
              font-size: 13px;
              font-weight: 300;
              color: rgba(245,239,230,0.7);
              line-height: 1.6;
              margin-top: 10px;
              max-height: 0;
              overflow: hidden;
              transition: max-height 0.4s ease, opacity 0.4s ease;
              opacity: 0;
            ">
              {plato.descripcion}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA carta completa -->
    <div id="menu-cta" style="
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64px 0 0;
  flex-direction: column;
  gap: 20px;
  text-align: center;
">
  <p style="
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: rgba(26,15,10,0.45);
    letter-spacing: 0.02em;
  ">
    Esto es solo una muestra — la carta completa tiene mucho más.
  </p>

  <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: center;">
    <a
      href="/menu"
      style="
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #f5efe6;
        background: #1a0f0a;
        padding: 16px 36px;
        border-radius: 4px;
        text-decoration: none;
        transition: all 0.2s;
      "
      onmouseover="this.style.background='#c8956c'; this.style.color='#1a0f0a'"
      onmouseout="this.style.background='#1a0f0a'; this.style.color='#f5efe6'"
    >
      Ver carta
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <path d="M7 17L17 7M17 7H7M17 7v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <a
      href="/menu-visual"
      style="
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #1a0f0a;
        background: transparent;
        padding: 16px 36px;
        border-radius: 4px;
        border: 1.5px solid rgba(26,15,10,0.2);
        text-decoration: none;
        transition: all 0.2s;
      "
      onmouseover="this.style.borderColor='#1a0f0a'"
      onmouseout="this.style.borderColor='rgba(26,15,10,0.2)'"
    >
      Ver menú con fotos
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <path d="M7 17L17 7M17 7H7M17 7v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</div>

  </div>
</section>

<style>
  .menu-card:hover .card-img {
    transform: scale(1.06);
    opacity: 1;
  }

  .menu-card:hover .card-desc {
    max-height: 80px !important;
    opacity: 1 !important;
  }

  @media (max-width: 900px) {
    #menu-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 560px) {
    #menu-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".menu-header", {
    opacity: 0, y: 40,
    duration: 0.9, ease: "power3.out",
    scrollTrigger: { trigger: ".menu-header", start: "top 85%" }
  });

  gsap.from(".menu-card", {
    opacity: 0, y: 50, scale: 0.97,
    duration: 0.8, ease: "power3.out",
    stagger: 0.08,
    scrollTrigger: { trigger: "#menu-grid", start: "top 85%" }
  });

  gsap.from("#menu-cta", {
    opacity: 0, y: 30,
    duration: 0.8, ease: "power3.out",
    scrollTrigger: { trigger: "#menu-cta", start: "top 90%" }
  });
</script>