---
const valores = [
  {
    numero: "01",
    titulo: "Origen",
    descripcion: "Trabajamos directamente con productores de Chiapas y Oaxaca. Cada grano tiene nombre, familia y altitud.",
  },
  {
    numero: "02",
    titulo: "Proceso",
    descripcion: "Tostamos en pequeños lotes cada semana. Sin conservadores, sin atajos. Solo tiempo y temperatura exacta.",
  },
  {
    numero: "03",
    titulo: "Comunidad",
    descripcion: "Este espacio nació para ser tuyo. Un lugar donde el tiempo se detiene y las conversaciones florecen.",
  },
];
---

<section id="nosotros" style="
  background: #1a0f0a;
  position: relative;
  overflow: hidden;
">

  <!-- Parte superior: imagen + texto lado a lado -->
  <div style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 90vh;
  " id="nosotros-split">

    <!-- Imagen izquierda -->
    <div style="
      position: relative;
      overflow: hidden;
    " id="nosotros-img-wrap">
      <img
        src="https://images.unsplash.com/photo-1442512595331-e89e73853f31?w=1200&q=80"
        alt="Nuestro café"
        id="nosotros-img"
        style="
          width: 100%;
          height: 100%;
          object-fit: cover;
          opacity: 0.75;
          transform: scale(1.05);
          transition: transform 0.1s linear;
        "
      />
      <!-- Overlay lateral -->
      <div style="
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, transparent 60%, #1a0f0a 100%);
      "></div>

      <!-- Año flotante -->
      <div style="
        position: absolute;
        bottom: 48px;
        left: 48px;
      ">
        <span style="
          font-family: 'Playfair Display', serif;
          font-size: 96px;
          font-weight: 800;
          color: rgba(200,149,108,0.15);
          line-height: 1;
          letter-spacing: -4px;
          user-select: none;
        ">2019</span>
      </div>
    </div>

    <!-- Contenido derecho -->
    <div style="
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 64px 80px 56px;
      position: relative;
      z-index: 1;
    " id="nosotros-content">

      <!-- Eyebrow -->
      <div style="
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
      ">
        <div style="height: 1px; width: 32px; background: #c8956c;"></div>
        <span style="
          font-family: 'DM Sans', sans-serif;
          font-size: 12px;
          font-weight: 500;
          letter-spacing: 0.2em;
          text-transform: uppercase;
          color: #c8956c;
        ">Nuestra historia</span>
      </div>

      <!-- Título -->
      <h2 style="
        font-family: 'Playfair Display', serif;
        font-size: clamp(36px, 4vw, 52px);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -1.5px;
        color: #f5efe6;
        margin-bottom: 28px;
      ">
        No vendemos café.<br/>
        <em style="font-style: italic; color: #c8956c;">Cultivamos</em><br/>
        momentos.
      </h2>

      <!-- Párrafos -->
      <p style="
        font-family: 'DM Sans', sans-serif;
        font-size: 16px;
        font-weight: 300;
        color: rgba(245,239,230,0.6);
        line-height: 1.8;
        margin-bottom: 16px;
        max-width: 420px;
      ">
        Origen nació en 2019 de una obsesión simple: encontrar la mejor taza posible y compartirla. Lo que empezó como una pequeña barra en la Colonia Roma hoy es un espacio donde cientos de personas comienzan su día.
      </p>
      <p style="
        font-family: 'DM Sans', sans-serif;
        font-size: 16px;
        font-weight: 300;
        color: rgba(245,239,230,0.6);
        line-height: 1.8;
        margin-bottom: 48px;
        max-width: 420px;
      ">
        Cada elemento en este espacio fue elegido con intención — desde la madera de los muebles hasta el origen de cada grano.
      </p>

      <!-- Stats -->
      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
        padding-top: 40px;
        border-top: 1px solid rgba(245,239,230,0.08);
      " id="nosotros-stats">
        {[
          { valor: "5+", label: "Años de historia" },
          { valor: "12", label: "Productores directos" },
          { valor: "200+", label: "Tazas al día" },
        ].map(stat => (
          <div>
            <div style="
              font-family: 'Playfair Display', serif;
              font-size: 40px;
              font-weight: 800;
              color: #c8956c;
              letter-spacing: -1.5px;
              line-height: 1;
              margin-bottom: 6px;
            ">{stat.valor}</div>
            <div style="
              font-family: 'DM Sans', sans-serif;
              font-size: 12px;
              font-weight: 500;
              letter-spacing: 0.05em;
              color: rgba(245,239,230,0.4);
              text-transform: uppercase;
            ">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Parte inferior: valores -->
  <div style="
    max-width: 1100px;
    margin: 0 auto;
    padding: 96px 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  " id="valores-grid">
    {valores.map((v) => (
      <div
        class="valor-item"
        style="
          padding: 48px 40px;
          border: 1px solid rgba(245,239,230,0.06);
          position: relative;
          transition: background 0.3s ease;
        "
        onmouseover="this.style.background='rgba(200,149,108,0.04)'"
        onmouseout="this.style.background='transparent'"
      >
        <div style="
          font-family: 'Playfair Display', serif;
          font-size: 64px;
          font-weight: 800;
          color: rgba(200,149,108,0.12);
          line-height: 1;
          letter-spacing: -2px;
          margin-bottom: 24px;
          user-select: none;
        ">{v.numero}</div>
        <h3 style="
          font-family: 'Playfair Display', serif;
          font-size: 24px;
          font-weight: 700;
          color: #f5efe6;
          margin-bottom: 14px;
          letter-spacing: -0.5px;
        ">{v.titulo}</h3>
        <p style="
          font-family: 'DM Sans', sans-serif;
          font-size: 14px;
          font-weight: 300;
          color: rgba(245,239,230,0.5);
          line-height: 1.75;
        ">{v.descripcion}</p>

        <!-- Línea decorativa bottom -->
        <div class="valor-line" style="
          position: absolute;
          bottom: 0;
          left: 40px;
          width: 0;
          height: 1px;
          background: #c8956c;
          transition: width 0.4s ease;
        "></div>
      </div>
    ))}
  </div>

</section>

<style>
  .valor-item:hover .valor-line {
    width: calc(100% - 80px) !important;
  }

  @media (max-width: 900px) {
    #nosotros-split {
      grid-template-columns: 1fr !important;
    }

    #nosotros-img-wrap {
      height: 50vh;
    }

    #nosotros-content {
      padding: 56px 24px !important;
    }

    #valores-grid {
      grid-template-columns: 1fr !important;
    }

    #nosotros-stats {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }

  @media (max-width: 480px) {
    #nosotros-stats {
      grid-template-columns: 1fr !important;
      gap: 24px !important;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Parallax imagen
  const img = document.getElementById("nosotros-img") as HTMLElement;
  const wrap = document.getElementById("nosotros-img-wrap") as HTMLElement;

  ScrollTrigger.create({
    trigger: "#nosotros",
    start: "top bottom",
    end: "bottom top",
    onUpdate: (self) => {
      const p = self.progress;
      gsap.set(img, { y: p * 60 - 30 });
    },
  });

  // Entrada contenido derecho
  gsap.from("#nosotros-content > *", {
    opacity: 0,
    x: 40,
    duration: 0.9,
    ease: "power3.out",
    stagger: 0.12,
    scrollTrigger: {
      trigger: "#nosotros-content",
      start: "top 80%",
    },
  });

  // Entrada imagen izquierda
  gsap.from("#nosotros-img-wrap", {
    opacity: 0,
    x: -40,
    duration: 1,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#nosotros-split",
      start: "top 80%",
    },
  });

  // Entrada valores
  gsap.from(".valor-item", {
    opacity: 0,
    y: 40,
    duration: 0.8,
    ease: "power3.out",
    stagger: 0.15,
    scrollTrigger: {
      trigger: "#valores-grid",
      start: "top 85%",
    },
  });
</script>