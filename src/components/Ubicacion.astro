---
---

<section id="ubicacion" style="
  background: #1a0f0a;
  position: relative;
  overflow: hidden;
">

  <!-- Grid principal: mapa + info -->
  <div style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  " id="ubicacion-grid">

    <!-- Mapa izquierda -->
    <div style="position: relative; overflow: hidden; min-height: 500px;" id="mapa-wrap">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3762.661849512225!2d-99.16446922394635!3d19.42706574107992!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1ff3b7db4b0d3%3A0x7e91b7e1c6d68e0b!2sColonia+Roma%2C+Ciudad+de+M%C3%A9xico!5e0!3m2!1ses!2smx!4v1700000000000!5m2!1ses!2smx"
        style="
          width: 100%;
          height: 100%;
          border: none;
          position: absolute;
          inset: 0;
          filter: grayscale(1) invert(0.9) sepia(0.3) brightness(0.7);
        "
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>

      <!-- Overlay sobre mapa -->
      <div style="
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, transparent 70%, #1a0f0a 100%);
        pointer-events: none;
        z-index: 1;
      "></div>

      <!-- Pin central decorativo -->
      <div style="
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2;
        pointer-events: none;
      ">
        <div style="
          width: 48px;
          height: 48px;
          border-radius: 50%;
          background: #c8956c;
          display: flex;
          align-items: center;
          justify-content: center;
          box-shadow: 0 0 0 12px rgba(200,149,108,0.15);
        " id="pin-pulse">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#1a0f0a"/>
          </svg>
        </div>
        <!-- Sombra del pin -->
        <div style="
          width: 8px;
          height: 4px;
          background: rgba(0,0,0,0.3);
          border-radius: 50%;
          margin: 4px auto 0;
          filter: blur(2px);
        "></div>
      </div>
    </div>

    <!-- Info derecha -->
    <div style="
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 64px 80px 56px;
      position: relative;
      z-index: 1;
    " id="ubicacion-info">

      <!-- Eyebrow -->
      <div style="
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
      ">
        <div style="height: 1px; width: 32px; background: #c8956c;"></div>
        <span style="
          font-family: 'DM Sans', sans-serif;
          font-size: 12px;
          font-weight: 500;
          letter-spacing: 0.2em;
          text-transform: uppercase;
          color: #c8956c;
        ">Encuéntranos</span>
      </div>

      <h2 style="
        font-family: 'Playfair Display', serif;
        font-size: clamp(36px, 4vw, 52px);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -1.5px;
        color: #f5efe6;
        margin-bottom: 40px;
      ">
        En el corazón<br/>
        de la <em style="font-style: italic; color: #c8956c;">Roma Norte</em>
      </h2>

      <!-- Datos de contacto -->
      <div style="
        display: flex;
        flex-direction: column;
        gap: 0;
        margin-bottom: 48px;
        border-top: 1px solid rgba(245,239,230,0.06);
      ">
        {[
          {
            icono: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/></svg>`,
            label: "Dirección",
            valor: "Orizaba 42, Col. Roma Norte, CDMX",
            href: "https://maps.google.com",
          },
          {
            icono: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="currentColor"/></svg>`,
            label: "Teléfono",
            valor: "+52 55 1234 5678",
            href: "tel:+5255123456789",
          },
          {
            icono: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" fill="currentColor"/></svg>`,
            label: "Email",
            valor: "hola@origencafe.mx",
            href: "mailto:hola@origencafe.mx",
          },
        ].map(item => (
          <a
            href={item.href}
            target="_blank"
            class="contacto-row"
            style="
              display: flex;
              align-items: center;
              gap: 16px;
              padding: 20px 0;
              border-bottom: 1px solid rgba(245,239,230,0.06);
              text-decoration: none;
              transition: all 0.2s;
              group: true;
            "
          >
            <div style="
              width: 40px;
              height: 40px;
              border-radius: 4px;
              background: rgba(200,149,108,0.1);
              display: flex;
              align-items: center;
              justify-content: center;
              color: #c8956c;
              flex-shrink: 0;
              transition: background 0.2s;
            " class="contacto-icon">
              <Fragment set:html={item.icono} />
            </div>
            <div>
              <div style="
                font-family: 'DM Sans', sans-serif;
                font-size: 11px;
                font-weight: 600;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: rgba(245,239,230,0.3);
                margin-bottom: 3px;
              ">{item.label}</div>
              <div style="
                font-family: 'DM Sans', sans-serif;
                font-size: 15px;
                font-weight: 400;
                color: rgba(245,239,230,0.8);
                transition: color 0.2s;
              " class="contacto-valor">{item.valor}</div>
            </div>
            <!-- Flecha -->
            <div style="
              margin-left: auto;
              color: rgba(245,239,230,0.15);
              transition: color 0.2s, transform 0.2s;
            " class="contacto-arrow">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M7 17L17 7M17 7H7M17 7v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA Google Maps -->
      <a
        href="https://maps.google.com"
        target="_blank"
        style="
          display: inline-flex;
          align-items: center;
          gap: 10px;
          font-family: 'DM Sans', sans-serif;
          font-size: 13px;
          font-weight: 600;
          letter-spacing: 0.08em;
          text-transform: uppercase;
          color: #1a0f0a;
          background: #c8956c;
          padding: 14px 28px;
          border-radius: 4px;
          text-decoration: none;
          transition: background 0.2s;
          width: fit-content;
        "
        onmouseover="this.style.background='#8b5e3c'; this.style.color='#f5efe6'"
        onmouseout="this.style.background='#c8956c'; this.style.color='#1a0f0a'"
      >
        Abrir en Google Maps
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
          <path d="M7 17L17 7M17 7H7M17 7v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Footer strip -->
  <div style="
    border-top: 1px solid rgba(245,239,230,0.06);
    padding: 28px 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  ">
    <span style="
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 700;
      color: #f5efe6;
      letter-spacing: -0.3px;
    ">Origen <em style="color: #c8956c; font-style: italic;">Café</em></span>

    <span style="
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: rgba(245,239,230,0.2);
    ">© 2025 Origen Café. Todos los derechos reservados.</span>

    <!-- Redes sociales -->
    <div style="display: flex; gap: 12px;">
      {[
        {
          nombre: "Instagram",
          href: "#",
          icono: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
        },
        {
          nombre: "Facebook",
          href: "#",
          icono: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
        },
        {
          nombre: "TikTok",
          href: "#",
          icono: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/></svg>`,
        },
      ].map(red => (
        <a
          href={red.href}
          aria-label={red.nombre}
          style="
            width: 36px;
            height: 36px;
            border-radius: 4px;
            border: 1px solid rgba(245,239,230,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(245,239,230,0.3);
            text-decoration: none;
            transition: all 0.2s;
          "
          onmouseover="this.style.borderColor='#c8956c'; this.style.color='#c8956c'"
          onmouseout="this.style.borderColor='rgba(245,239,230,0.1)'; this.style.color='rgba(245,239,230,0.3)'"
        >
          <Fragment set:html={red.icono} />
        </a>
      ))}
    </div>
  </div>

</section>

<style>
  .contacto-row:hover .contacto-icon {
    background: rgba(200,149,108,0.2) !important;
  }

  .contacto-row:hover .contacto-valor {
    color: #f5efe6 !important;
  }

  .contacto-row:hover .contacto-arrow {
    color: #c8956c !important;
    transform: translate(3px, -3px);
  }

  @media (max-width: 900px) {
    #ubicacion-grid {
      grid-template-columns: 1fr !important;
    }

    #mapa-wrap {
      min-height: 380px !important;
    }

    #ubicacion-info {
      padding: 56px 24px !important;
    }

    footer-strip {
      padding: 24px !important;
      flex-direction: column !important;
      align-items: flex-start !important;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Entrada mapa
  gsap.from("#mapa-wrap", {
    opacity: 0,
    x: -40,
    duration: 1,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#ubicacion-grid",
      start: "top 80%",
    },
  });

  // Entrada info
  gsap.from("#ubicacion-info > *", {
    opacity: 0,
    x: 40,
    duration: 0.9,
    ease: "power3.out",
    stagger: 0.1,
    scrollTrigger: {
      trigger: "#ubicacion-info",
      start: "top 80%",
    },
  });

  // Pin pulse
  gsap.to("#pin-pulse", {
    boxShadow: "0 0 0 20px rgba(200,149,108,0)",
    duration: 1.5,
    ease: "power2.out",
    repeat: -1,
  });

  // Footer strip entrada
  gsap.from(".footer-strip", {
    opacity: 0,
    y: 20,
    duration: 0.8,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".footer-strip",
      start: "top 95%",
    },
  });
</script>