<script>
  import { gsap } from "gsap";

  const preloader = document.getElementById("preloader") as HTMLElement;
  const pageContent = document.getElementById("page-content") as HTMLElement;
  const progressBar = document.getElementById("progress-bar") as HTMLElement;
  const progressNum = document.getElementById("progress-num") as HTMLElement;

  const imgs = Array.from(document.querySelectorAll<HTMLImageElement>(".preload-hidden"));
  const total = imgs.length;
  let loaded = 0;
  let revealed = false;

  function revealPage() {
    if (revealed) return;
    revealed = true;

    setTimeout(() => {
      gsap.to(preloader, {
        opacity: 0,
        duration: 0.8,
        ease: "power2.inOut",
        onComplete: () => {
          preloader.style.display = "none";
        },
      });

      gsap.to(pageContent, {
        opacity: 1,
        duration: 0.6,
        ease: "power2.out",
        delay: 0.3,
      });

      gsap.from("#carta-hero > div > *", {
        opacity: 0,
        y: 20,
        duration: 0.7,
        ease: "power3.out",
        stagger: 0.1,
        delay: 0.6,
      });
    }, 300);
  }

  function onImageLoad() {
    loaded++;
    const pct = Math.round((loaded / total) * 100);
    progressBar.style.width = `${pct}%`;
    progressNum.textContent = `${pct}%`;
    if (loaded >= total) revealPage();
  }

  if (total === 0) {
    revealPage();
  } else {
    imgs.forEach(img => {
      if (img.complete && img.naturalWidth > 0) {
        onImageLoad();
      } else {
        img.addEventListener("load", onImageLoad);
        img.addEventListener("error", onImageLoad);
      }
    });
  }

  setTimeout(() => { revealPage(); }, 8000);

  // Todos los tabs
  const tabs = document.querySelectorAll<HTMLElement>(".cat-tab");
  const sideTabs = document.querySelectorAll<HTMLElement>(".side-tab");
  const mobileTabs = document.querySelectorAll<HTMLElement>(".mobile-tab");
  const secciones = document.querySelectorAll<HTMLElement>(".carta-seccion");

  function scrollToSeccion(id: string) {
    const target = document.getElementById(id);
    if (!target) return;
    window.scrollTo({ top: target.offsetTop - 100, behavior: "smooth" });
  }

  tabs.forEach(tab => tab.addEventListener("click", () => scrollToSeccion(tab.dataset.target!)));
  sideTabs.forEach(tab => tab.addEventListener("click", () => scrollToSeccion(tab.dataset.target!)));
  mobileTabs.forEach(tab => tab.addEventListener("click", () => scrollToSeccion(tab.dataset.target!)));

  // Observer unificado — maneja los 3 tipos de tabs
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;

        tabs.forEach(t => t.classList.remove("active"));
        sideTabs.forEach(t => t.classList.remove("active"));
        mobileTabs.forEach(t => t.classList.remove("active"));

        document.querySelector<HTMLElement>(`.cat-tab[data-target="${id}"]`)?.classList.add("active");
        document.querySelector<HTMLElement>(`.side-tab[data-target="${id}"]`)?.classList.add("active");

        const activeMobileTab = document.querySelector<HTMLElement>(`.mobile-tab[data-target="${id}"]`);
        if (activeMobileTab) {
          activeMobileTab.classList.add("active");
          activeMobileTab.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
        }
      }
    });
  }, { threshold: 0.25, rootMargin: "-80px 0px 0px 0px" });

  secciones.forEach(s => observer.observe(s));
</script>