      { nombre: "Cold Brew", descripcion: "Infusión en frío 18 horas. Notas de chocolate y caramelo.", precio: "$85", badge: "Origen único", imagen: "https://images.unsplash.com/photo-1517701604599-bb29b565090c?w=600&q=80" },
      { nombre: "Latte Helado", descripcion: "Espresso doble sobre hielo con leche fría texturizada.", precio: "$80", badge: null, imagen: "https://images.unsplash.com/photo-1461023058943-07fcbe16d735?w=600&q=80" },
      { nombre: "Limonada Menta", descripcion: "Limones frescos, menta de la huerta, agua mineral y miel.", precio: "$65", badge: null, imagen: "https://images.unsplash.com/photo-1621263764928-df1444c5e859?w=600&q=80" },
      { nombre: "Smoothie Verde", descripcion: "Espinaca, manzana verde, pepino, jengibre y agua de coco.", precio: "$90", badge: null, imagen: "https://images.unsplash.com/photo-1610970881699-44a5587cabec?w=600&q=80" },
    ],
  },
  {
    categoria: "Postres",
    descripcion: "Elaborados en casa cada mañana",
    platillos: [
      { nombre: "Tarta de Limón", descripcion: "Base de galleta, crema de limón amarillo y merengue italiano tostado.", precio: "$95", badge: "Temporada", imagen: "https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=600&q=80" },
      { nombre: "Brownie Fondant", descripcion: "Chocolate belga 70%, centro líquido y helado de vainilla de Madagascar.", precio: "$110", badge: null, imagen: "https://images.unsplash.com/photo-1606313564200-e75d5e30476c?w=600&q=80" },
      { nombre: "Cheesecake New York", descripcion: "Clásico horneado con base de galleta y coulis de frutos rojos.", precio: "$100", badge: "Favorito", imagen: "https://images.unsplash.com/photo-1533134242443-d4fd215305ad?w=600&q=80" },
      { nombre: "Croissant de Almendra", descripcion: "Croissant artesanal relleno de crema de almendra y azúcar glass.", precio: "$85", badge: null, imagen: "https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=600&q=80" },
    ],
  },
];

// Extraer todas las imágenes para el preloader
const todasLasImagenes = carta.flatMap(s => s.platillos.map(p => p.imagen));
---

<Layout
  title="Menú — Origen Café"
  description="Nuestra carta completa con fotografía de cada platillo."
>

  <!-- Preloader -->
  <div id="preloader" style="
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #1a0f0a;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
  ">
    <!-- Logo -->
    <div style="text-align: center;">
      <div style="
        font-family: 'Playfair Display', serif;
        font-size: 32px;
        font-weight: 800;
        color: #f5efe6;
        letter-spacing: -1px;
        margin-bottom: 4px;
      ">Origen</div>
      <div style="
        font-family: 'DM Sans', sans-serif;
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #c8956c;
      ">Café & Brunch</div>
    </div>

    <!-- Barra de progreso -->
    <div style="
      width: 180px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    ">
      <div style="
        width: 100%;
        height: 1px;
        background: rgba(245,239,230,0.1);
        border-radius: 99px;
        overflow: hidden;
      ">
        <div id="progress-bar" style="
          height: 100%;
          width: 0%;
          background: #c8956c;
          border-radius: 99px;
          transition: width 0.2s ease;
        "></div>
      </div>
      <div style="
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      ">
        <span style="
          font-family: 'DM Sans', sans-serif;
          font-size: 11px;
          font-weight: 400;
          color: rgba(245,239,230,0.3);
          letter-spacing: 0.1em;
        ">Cargando menú</span>
        <span id="progress-num" style="
          font-family: 'Playfair Display', serif;
          font-size: 13px;
          font-weight: 600;
          color: #c8956c;
        ">0%</span>
      </div>
    </div>

    <!-- Detalle decorativo -->
    <div style="
      display: flex;
      align-items: center;
      gap: 8px;
      opacity: 0.25;
    ">
      <div style="height: 1px; width: 20px; background: #f5efe6;"></div>
      <div style="
        font-family: 'DM Sans', sans-serif;
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #f5efe6;
      ">Est. 2019</div>
      <div style="height: 1px; width: 20px; background: #f5efe6;"></div>
    </div>
  </div>

  <!-- Contenido (oculto hasta que cargue) -->
  <div id="page-content" style="opacity: 0;">

    <!-- Navbar -->
    <header style="
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 50;
      background: #f5efe6;
      border-bottom: 1px solid rgba(26,15,10,0.08);
      padding: 0 40px;
    ">
      <div style="
        max-width: 1200px;
        margin: 0 auto;
        padding: 16px 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      ">
        <a href="/" style="text-decoration: none; flex-shrink: 0; display: flex; flex-direction: column; line-height: 1;">
          <span style="font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: #1a0f0a; letter-spacing: -0.3px;">Origen</span>
          <span style="font-family: 'DM Sans', sans-serif; font-size: 9px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: #c8956c;">Café & Brunch</span>
        </a>

        <nav id="cat-nav" style="
          display: flex;
          align-items: center;
          gap: 2px;
          overflow-x: auto;
          scrollbar-width: none;
          flex: 1;
          justify-content: center;
        ">
          {carta.map((s, i) => (
            <button
              class="cat-tab"
              data-target={`seccion-${i}`}
              style="
                font-family: 'DM Sans', sans-serif;
                font-size: 12px;
                font-weight: 500;
                letter-spacing: 0.03em;
                color: rgba(26,15,10,0.4);
                background: none;
                border: none;
                padding: 7px 14px;
                border-radius: 4px;
                cursor: pointer;
                transition: all 0.2s;
                white-space: nowrap;
              "
            >
              {s.categoria}
            </button>
          ))}
        </nav>

        <a href="/" style="
          font-family: 'DM Sans', sans-serif;
          font-size: 12px;
          font-weight: 600;
          letter-spacing: 0.06em;
          text-transform: uppercase;
          color: rgba(26,15,10,0.45);
          text-decoration: none;
          display: flex;
          align-items: center;
          gap: 6px;
          flex-shrink: 0;
          transition: color 0.2s;
        "
        onmouseover="this.style.color='#1a0f0a'"
        onmouseout="this.style.color='rgba(26,15,10,0.45)'"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
            <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Inicio
        </a>
      </div>
    </header>

    <main style="padding-top: 72px; background: #f5efe6; min-height: 100vh;">

      <!-- Hero -->
      <div id="carta-hero" style="
        background: #1a0f0a;
        padding: 64px 40px 56px;
        position: relative;
        overflow: hidden;
      ">
        <div style="
          position: absolute;
          top: -100px; left: 50%;
          transform: translateX(-50%);
          width: 700px; height: 400px;
          background: radial-gradient(ellipse, rgba(200,149,108,0.12) 0%, transparent 65%);
          pointer-events: none;
        "></div>
        <div style="max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
            <div style="height: 1px; width: 28px; background: #c8956c;"></div>
            <span style="font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: #c8956c;">Menú completo</span>
          </div>
          <h1 style="
            font-family: 'Playfair Display', serif;
            font-size: clamp(36px, 5vw, 64px);
            font-weight: 800;
            line-height: 1.0;
            letter-spacing: -2px;
            color: #f5efe6;
          ">
            Todo lo que<br/>
            <em style="font-style: italic; color: #c8956c;">preparamos</em> hoy
          </h1>
        </div>
      </div>

      <!-- Tab bar mobile — solo visible en mobile -->
<div id="mobile-tabs" style="
  display: none;
  position: sticky;
  top: 57px;
  z-index: 40;
  background: #f5efe6;
  border-bottom: 1px solid rgba(26,15,10,0.08);
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
">
  <div style="
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 10px 16px;
    width: max-content;
  ">
    {carta.map((s, i) => (
      <button
        class="mobile-tab"
        data-target={`seccion-${i}`}
        style="
          font-family: 'DM Sans', sans-serif;
          font-size: 12px;
          font-weight: 500;
          letter-spacing: 0.03em;
          color: rgba(26,15,10,0.45);
          background: rgba(26,15,10,0.05);
          border: none;
          padding: 7px 14px;
          border-radius: 100px;
          cursor: pointer;
          transition: all 0.2s;
          white-space: nowrap;
        "
      >
        {s.categoria}
      </button>
    ))}
  </div>
</div>

      <!-- Layout sidebar + lista -->
      <div style="
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 0;
        align-items: start;
        padding: 0 40px;
      " id="menu-layout">

        <!-- Sidebar -->
        <aside id="sidebar" style="
          position: sticky;
          top: 88px;
          padding: 48px 0;
          border-right: 1px solid rgba(26,15,10,0.07);
        ">
          <p style="
            font-family: 'DM Sans', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: rgba(26,15,10,0.3);
            margin-bottom: 16px;
          ">Categorías</p>
          <nav style="display: flex; flex-direction: column; gap: 2px;">
            {carta.map((s, i) => (
              <button
                class="side-tab"
                data-target={`seccion-${i}`}
                style="
                  font-family: 'DM Sans', sans-serif;
                  font-size: 13px;
                  font-weight: 500;
                  color: rgba(26,15,10,0.4);
                  background: none;
                  border: none;
                  padding: 9px 12px 9px 0;
                  text-align: left;
                  cursor: pointer;
                  transition: all 0.2s;
                  border-left: 2px solid transparent;
                  display: flex;
                  align-items: center;
                  justify-content: space-between;
                "
              >
                {s.categoria}
                <span style="font-size: 11px; color: rgba(26,15,10,0.2);">{s.platillos.length}</span>
              </button>
            ))}
          </nav>
        </aside>

        <!-- Lista platillos -->
        <div style="padding: 48px 0 48px 48px;">
          {carta.map((seccion, si) => (
            <div
              class="carta-seccion"
              id={`seccion-${si}`}
              style={`
                padding-bottom: 64px;
                margin-bottom: 64px;
                ${si < carta.length - 1 ? 'border-bottom: 1px solid rgba(26,15,10,0.07);' : ''}
              `}
            >
              <div style="
                display: flex;
                align-items: baseline;
                justify-content: space-between;
                margin-bottom: 32px;
                flex-wrap: wrap;
                gap: 8px;
              ">
                <h2 style="
                  font-family: 'Playfair Display', serif;
                  font-size: clamp(24px, 3vw, 36px);
                  font-weight: 800;
                  letter-spacing: -1px;
                  color: #1a0f0a;
                  line-height: 1;
                ">{seccion.categoria}</h2>
                <span style="
                  font-family: 'DM Sans', sans-serif;
                  font-size: 12px;
                  color: rgba(26,15,10,0.35);
                  font-style: italic;
                ">{seccion.descripcion}</span>
              </div>

              <div style="display: flex; flex-direction: column; gap: 2px;">
                {seccion.platillos.map((p) => (
                <div class="platillo-item" style="
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 0;
  background: #ffffff;
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid rgba(26,15,10,0.05);
  transition: all 0.3s;
  cursor: default;
">
<!-- Imagen — sin badge -->
<div style="
  position: relative;
  overflow: hidden;
  min-height: 100px;
  align-self: stretch;
">
  <img
    src={p.imagen}
    alt={p.nombre}
    class="platillo-img preload-img"
    style="
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    "
  />
</div>

  <!-- Info — badge aquí -->
  <div style="
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
  ">
    <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;">
      <h3 style="
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
        color: #1a0f0a;
        letter-spacing: -0.3px;
        line-height: 1.2;
      ">{p.nombre}</h3>
      <span style="
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
        color: #c8956c;
        white-space: nowrap;
        flex-shrink: 0;
      ">{p.precio}</span>
    </div>

    {p.badge && (
      <div style="
        display: inline-flex;
        width: fit-content;
        font-family: 'DM Sans', sans-serif;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #c8956c;
        border: 1px solid rgba(200,149,108,0.35);
        padding: 3px 8px;
        border-radius: 2px;
      ">{p.badge}</div>
    )}

    <p style="
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 300;
      color: rgba(26,15,10,0.5);
      line-height: 1.65;
      max-width: 480px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    ">{p.descripcion}</p>
  </div>
</div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Footer -->
      <div style="border-top: 1px solid rgba(26,15,10,0.08); background: #1a0f0a; padding: 40px;">
        <div style="
          max-width: 1200px;
          margin: 0 auto;
          display: flex;
          align-items: center;
          justify-content: space-between;
          flex-wrap: wrap;
          gap: 20px;
        ">
          <div>
            <p style="font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 600; color: #f5efe6; margin-bottom: 4px;">¿Tienes alguna alergia o restricción?</p>
            <p style="font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 300; color: rgba(245,239,230,0.4);">Díselo a tu mesero — con gusto adaptamos cualquier platillo.</p>
          </div>
          <a
            href="/#reservaciones"
            style="
