      { nombre: "Hummus con Verduras", descripcion: "Hummus casero con aceite de oliva, pimentón y bastones de verdura fresca.", precio: "$115", badge: null, imagen: "https://images.unsplash.com/photo-1577805947697-89e18249d767?w=600&q=80" },
      { nombre: "Bruschetta Trío", descripcion: "Tres versiones: jitomate-albahaca, ricotta-miel y aguacate-limón.", precio: "$160", badge: "Chef's pick", imagen: "https://images.unsplash.com/photo-1572695157366-5e585ab2b69f?w=600&q=80" },
