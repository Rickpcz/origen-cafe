      { nombre: "César Clásica", descripcion: "Lechuga romana, aderezo César casero, crutones de masa madre y parmesano.", precio: "$140", badge: null, imagen: "https://images.unsplash.com/photo-1550304943-4f24f54ddde9?w=600&q=80" },
      { nombre: "Betabel y Queso de Cabra", descripcion: "Betabel rostizado, queso de cabra, arúgula, nuez y vinagreta de naranja.", precio: "$150", badge: "Temporada", imagen: "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=600&q=80" },
      { nombre: "Quinoa con Vegetales", descripcion: "Quinoa, calabaza rostizada, espinaca, semillas de girasol y aderezo tahini.", precio: "$145", badge: null, imagen: "https://images.unsplash.com/photo-1585032226651-759b368d7246?w=600&q=80" },
    ],
  },
  {
    categoria: "Bebidas Calientes",
    descripcion: "Café de especialidad y más",
    platillos: [
      { nombre: "Espresso", descripcion: "Doble shot. Origen: Chiapas, tostión media. Notas de cajeta y cítrico.", precio: "$55", badge: null, imagen: "https://images.unsplash.com/photo-1510707577719-ae7c14805e3a?w=600&q=80" },
      { nombre: "Americano", descripcion: "Espresso doble con agua caliente filtrada. Limpio y profundo.", precio: "$60", badge: null, imagen: "https://images.unsplash.com/photo-1497935586351-b67a49e012bf?w=600&q=80" },
      { nombre: "Latte", descripcion: "Espresso doble con leche texturizada al vapor. Suave y cremoso.", precio: "$75", badge: "Favorito", imagen: "https://images.unsplash.com/photo-1461023058943-07fcbe16d735?w=600&q=80" },
      { nombre: "Cappuccino", descripcion: "Espresso, leche vaporizada y espuma sedosa en proporciones exactas.", precio: "$70", badge: null, imagen: "https://images.unsplash.com/photo-1572442388796-11668a67e53d?w=600&q=80" },
      { nombre: "Matcha Latte", descripcion: "Matcha ceremonial japonés con leche de avena. Herbáceo y reconfortante.", precio: "$80", badge: null, imagen: "https://images.unsplash.com/photo-1536256263959-770b48d82b0a?w=600&q=80" },
      { nombre: "Chocolate Caliente", descripcion: "Cacao 70% de Tabasco con leche entera y un toque de canela.", precio: "$80", badge: null, imagen: "https://images.unsplash.com/photo-1542990253-0d0f5be5f0ed?w=600&q=80" },
    ],
  },
  {
    categoria: "Bebidas Frías",
    descripcion: "Refrescantes y artesanales",
